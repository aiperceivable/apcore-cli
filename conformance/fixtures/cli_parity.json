{
  "description": "CLI argument and output parity (Algorithm C01)",
  "test_cases": [
    {
      "id": "exec_command_output",
      "args": ["exec", "math.add", "--input", "{\"a\": 1, \"b\": 2}", "--format", "json"],
      "expected_json_output": {
        "module_id": "math.add",
        "result": { "sum": 3 },
        "status": "success",
        "trace_id": "string_uuid_v4"
      }
    },
    {
      "id": "list_command_keys",
      "args": ["list", "--format", "json"],
      "expected_json_keys": [
        "module_id",
        "version",
        "description",
        "tags"
      ]
    },
    {
      "id": "error_exit_codes",
      "args": ["exec", "non_existent_module"],
      "expected_exit_code": 44,
      "expected_stderr_contains": "not found"
    }
  ]
}
